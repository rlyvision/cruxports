# Description: Highly customizable irc client
# URL: https://halloy.chat
# Maintainer: Hamza E. hamzaelasmar12 at gmail dot com
# Depends on: alsa-lib openssl xorg-libxcb rust git
name=halloy
version=2026.5
release=1
source=(https://github.com/squidowl/$name/archive/refs/tags/$version.tar.gz)
build() {
    cargo build --manifest-path $name-$version/Cargo.toml --release
    cargo install --path $name-$version --root $PKG    
}
