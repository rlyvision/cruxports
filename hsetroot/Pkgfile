# Description: wallpaper handler
# URL: github.com/himdel/hsetroot
# Maintainer: Hamza E. , hamzaelasmar12 at gmail dot com
# Depends on: imlib2 xorg-libxinerama

name=hsetroot
version=1.0.5
release=1
source=(https://github.com/himdel/$name/archive/$version.tar.gz)

build() {
    cd $name-$version
    mkdir -p $PKG/usr/bin
    make
    make install PREFIX=$PKG/usr
}
